# ===== LLM Providers =====
# Upstream TradingAgents keys (set these OR the SKOPAQ_ variants below)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Skopaq-prefixed keys (bridged automatically to standard vars above)
SKOPAQ_GOOGLE_API_KEY=
SKOPAQ_ANTHROPIC_API_KEY=
SKOPAQ_XAI_API_KEY=
SKOPAQ_PERPLEXITY_API_KEY=
SKOPAQ_OPENROUTER_API_KEY=

# ===== Supabase =====
SKOPAQ_SUPABASE_URL=https://your-project.supabase.co
SKOPAQ_SUPABASE_ANON_KEY=eyJ...
SKOPAQ_SUPABASE_SERVICE_KEY=eyJ...

# ===== Upstash Redis =====
SKOPAQ_UPSTASH_REDIS_URL=https://your-redis.upstash.io
SKOPAQ_UPSTASH_REDIS_TOKEN=AX...

# ===== INDstocks Broker =====
SKOPAQ_INDSTOCKS_TOKEN=
SKOPAQ_INDSTOCKS_BASE_URL=https://api.indstocks.com

# ===== Trading Mode =====
# paper = simulated trades, live = real money via INDstocks
SKOPAQ_TRADING_MODE=paper

# ===== Asset Class =====
# equity = Indian equities (NSE/BSE), crypto = Binance Spot
SKOPAQ_ASSET_CLASS=equity
SKOPAQ_CRYPTO_QUOTE_CURRENCY=USDT
SKOPAQ_BINANCE_BASE_URL=https://api.binance.com

# ===== Scanner =====
# Enable background scanner (30s cycle on NIFTY 50 watchlist)
SKOPAQ_SCANNER_ENABLED=false
SKOPAQ_SCANNER_CYCLE_SECONDS=30
SKOPAQ_SCANNER_MAX_CANDIDATES=5

# ===== Cloudflare Tunnel (for static IP) =====
SKOPAQ_CF_TUNNEL_ID=

# ===== Semantic Cache (Redis LangCache) =====
SKOPAQ_LANGCACHE_ENABLED=false
SKOPAQ_LANGCACHE_API_KEY=
SKOPAQ_LANGCACHE_SERVER_URL=https://aws-ap-south-1.langcache.redis.io
SKOPAQ_LANGCACHE_CACHE_ID=
SKOPAQ_LANGCACHE_THRESHOLD=0.90

# ===== Frontend (Next.js) =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=http://localhost:8000
